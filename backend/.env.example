# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Oracle
DB_USER=your_user
DB_PASSWORD=your_password
DB_CONNECT_STRING=host:port/service
DB_POOL_MIN=1
DB_POOL_MAX=4
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT=60
DB_STATEMENT_TIMEOUT_MS=8000
PRIORITA_DEFAULT=3

# Oracle client (opzionale, necessario per modalità thick)
# DB_LIB_DIR=C:\\oracle\\instantclient_21_10
